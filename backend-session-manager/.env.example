APP_ENV=dev
HOST=0.0.0.0
PORT=8080
DATABASE_URL=sqlite:///./session_manager.db
STORAGE_DIR=./storage
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
DEFAULT_CHUNK_MS=7000
MAX_IN_FLIGHT_REQUESTS=1
