# ── Root .dockerignore ──────────────────────────
# Applies to images built with context: . (clinical-recommendations)

# PDFs are downloaded/extracted into a Docker volume at runtime.
# The embedding parquet is tracked and copied into the image.
clinical_recommendations/pdf_files/
clinical_recommendations/pdf_archive.zip

# Other services (they have their own build contexts)
frontend/
transcribation/
backend-session-manager/
real_time_analysis/
knowledge-extractor/

# Dev / VCS artifacts
.git/
.github/
.env
.env.*
!.env.example
**/__pycache__/
**/*.pyc
**/node_modules/
**/.venv/
