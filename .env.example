# Copy to `.env` and change only the values you need for your deployment.

KAGGLE_API_TOKEN=
KAGGLE_USERNAME=
KAGGLE_KEY=

TRANSCRIBATION_USE_GROQ_API=true
TRANSCRIBATION_GROQ_API_KEY=
TRANSCRIBATION_GROQ_MODEL=whisper-large-v3-turbo

REALTIME_ANALYSIS_LANGUAGE=ru
REALTIME_ANALYSIS_TIMEOUT_SECONDS=8
REALTIME_ANALYSIS_LLM_PROVIDER=ollama
REALTIME_ANALYSIS_MODEL_NAME=qwen3:4b
REALTIME_ANALYSIS_LLM_BASE_URL=http://host.docker.internal:11434
REALTIME_ANALYSIS_LLM_API_KEY=
REALTIME_ANALYSIS_LLM_HTTP_REFERER=
REALTIME_ANALYSIS_LLM_X_TITLE=MedCoPilot
REALTIME_ANALYSIS_LLM_EXTRA_HEADERS_JSON=
REALTIME_ANALYSIS_LLM_REASONING_EFFORT=low
REALTIME_ANALYSIS_MAX_TOKENS=1024
REALTIME_ANALYSIS_TEMPERATURE=0.0
REALTIME_ANALYSIS_LLM_TIMEOUT=15.0
REALTIME_ANALYSIS_LOG_LEVEL=INFO

MEDCOPILOT_FHIR_BASE_URL=
MEDCOPILOT_FHIR_HEADERS_JSON=
MEDCOPILOT_FHIR_VERIFY_SSL=true

REALTIME_ANALYSIS_FHIR_BASE_URL=
REALTIME_ANALYSIS_FHIR_HEADERS_JSON=
REALTIME_ANALYSIS_FHIR_VERIFY_SSL=

KNOWLEDGE_EXTRACTOR_BACKEND=llm
KNOWLEDGE_EXTRACTOR_FHIR_BASE_URL=
KNOWLEDGE_EXTRACTOR_FHIR_HEADERS_JSON=
KNOWLEDGE_EXTRACTOR_FHIR_VERIFY_SSL=
KNOWLEDGE_EXTRACTOR_HTTP_TIMEOUT_SECONDS=10
KNOWLEDGE_EXTRACTOR_FHIR_MAX_RETRIES=1
KNOWLEDGE_EXTRACTOR_OLLAMA_BASE_URL=http://host.docker.internal:11434
KNOWLEDGE_EXTRACTOR_OLLAMA_MODEL=qwen3:4b-q4_K_M
KNOWLEDGE_EXTRACTOR_OLLAMA_TIMEOUT_SECONDS=60
KNOWLEDGE_EXTRACTOR_OLLAMA_TEMPERATURE=0.0
KNOWLEDGE_EXTRACTOR_LLM_TIMEOUT_SECONDS=20
KNOWLEDGE_EXTRACTOR_LLM_MAX_TOKENS=2048
KNOWLEDGE_EXTRACTOR_LLM_TEMPERATURE=0.0
KNOWLEDGE_EXTRACTOR_LOG_LEVEL=INFO

POST_ANALYTICS_LLM_BASE_URL=https://openrouter.ai/api/v1
POST_ANALYTICS_MODEL_NAME=gpt-oss-120b
POST_ANALYTICS_DIARIZATION_MODEL_NAME=openai/gpt-oss-20b
POST_ANALYTICS_LLM_API_KEY=
POST_ANALYTICS_FALLBACK_MODEL_NAMES=openai/gpt-oss-20b,llama-3.1-8b-instant
POST_ANALYTICS_MAX_TOKENS=4096
POST_ANALYTICS_TEMPERATURE=0.1
POST_ANALYTICS_TIMEOUT=120.0
POST_ANALYTICS_LLM_HTTP_REFERER=
POST_ANALYTICS_LLM_X_TITLE=MedCoPilot
POST_ANALYTICS_LLM_EXTRA_HEADERS_JSON=
POST_ANALYTICS_LOG_LEVEL=INFO

CLINICAL_RECOMMENDATIONS_EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-small
CLINICAL_RECOMMENDATIONS_EMBEDDING_QUERY_PREFIX=query: 
CLINICAL_RECOMMENDATIONS_EMBEDDING_PASSAGE_PREFIX=passage: 
CLINICAL_RECOMMENDATIONS_EMBEDDING_TOKEN_LIMIT=512
CLINICAL_RECOMMENDATIONS_EMBEDDING_BATCH_SIZE=8
