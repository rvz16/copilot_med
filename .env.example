# Environment overrides for the root MedCoPilot Docker Compose stack.
# Copy this file to `.env` in the repository root and fill in only the values you need.

# Optional Kaggle credentials for the Whisper model download.
KAGGLE_API_TOKEN=
KAGGLE_USERNAME=
KAGGLE_KEY=

TRANSCRIBATION_USE_GROQ_API=true
TRANSCRIBATION_GROQ_API_KEY=your_groq_api_key_here
TRANSCRIBATION_GROQ_MODEL=whisper-large-v3-turbo
# Language sent with realtime analysis requests.
REALTIME_ANALYSIS_LANGUAGE=ru
REALTIME_ANALYSIS_TIMEOUT_SECONDS=20

# Realtime analysis LLM settings.
# Supported values for `REALTIME_ANALYSIS_LLM_PROVIDER`:
#   ollama
#   openai_compatible
REALTIME_ANALYSIS_LLM_PROVIDER=ollama
REALTIME_ANALYSIS_MODEL_NAME=qwen3:4b
REALTIME_ANALYSIS_LLM_BASE_URL=http://host.docker.internal:11434
REALTIME_ANALYSIS_LLM_API_KEY=
REALTIME_ANALYSIS_LLM_HTTP_REFERER=
REALTIME_ANALYSIS_LLM_X_TITLE=MedCoPilot
REALTIME_ANALYSIS_LLM_EXTRA_HEADERS_JSON=
REALTIME_ANALYSIS_FHIR_BASE_URL=http://fhir:8092/fhir
REALTIME_ANALYSIS_MAX_TOKENS=1024
REALTIME_ANALYSIS_TEMPERATURE=0.0
REALTIME_ANALYSIS_LLM_TIMEOUT=15.0
# Reasoning effort for reasoning models (`low`, `medium`, or `high`).
# `low` is recommended to keep JSON output compact.
REALTIME_ANALYSIS_LLM_REASONING_EFFORT=low
REALTIME_ANALYSIS_LOG_LEVEL=INFO

# Example OpenRouter configuration:
# REALTIME_ANALYSIS_LLM_PROVIDER=openai_compatible
# REALTIME_ANALYSIS_MODEL_NAME=openai/gpt-oss-20b:free
# REALTIME_ANALYSIS_LLM_BASE_URL=https://openrouter.ai/api/v1
# REALTIME_ANALYSIS_LLM_API_KEY=your_openrouter_key
# REALTIME_ANALYSIS_LLM_HTTP_REFERER=http://localhost:3000
# REALTIME_ANALYSIS_LLM_X_TITLE=MedCoPilot

# Example Groq configuration:
# REALTIME_ANALYSIS_LLM_PROVIDER=openai_compatible
# REALTIME_ANALYSIS_MODEL_NAME=openai/gpt-oss-20b
# REALTIME_ANALYSIS_LLM_BASE_URL=https://api.groq.com/openai/v1
# REALTIME_ANALYSIS_LLM_API_KEY=your_groq_key
# REALTIME_ANALYSIS_LLM_HTTP_REFERER=http://localhost:3000
# REALTIME_ANALYSIS_LLM_X_TITLE=MedCoPilot

# Post-session analytics settings for deeper consultation review.
# This service uses a larger model and requires an OpenAI-compatible API.
POST_ANALYTICS_LLM_BASE_URL=https://openrouter.ai/api/v1
POST_ANALYTICS_MODEL_NAME=gpt-oss-120b
POST_ANALYTICS_LLM_API_KEY=your_openrouter_key_here
# Optional fallback chain if the primary model is rate-limited or temporarily unavailable.
# Example for Groq: a smaller GPT-OSS model first, then Llama 3.1 8B.
POST_ANALYTICS_FALLBACK_MODEL_NAMES=openai/gpt-oss-20b,llama-3.1-8b-instant
POST_ANALYTICS_MAX_TOKENS=4096
POST_ANALYTICS_TEMPERATURE=0.1
POST_ANALYTICS_TIMEOUT=120.0
POST_ANALYTICS_LLM_HTTP_REFERER=http://localhost:3000
POST_ANALYTICS_LLM_X_TITLE=MedCoPilot
POST_ANALYTICS_LLM_EXTRA_HEADERS_JSON=
POST_ANALYTICS_LOG_LEVEL=INFO

# Example Google AI Developer compatibility configuration:
# REALTIME_ANALYSIS_LLM_PROVIDER=openai_compatible
# REALTIME_ANALYSIS_MODEL_NAME=gemini-2.0-flash
# REALTIME_ANALYSIS_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# REALTIME_ANALYSIS_LLM_API_KEY=your_google_ai_key
